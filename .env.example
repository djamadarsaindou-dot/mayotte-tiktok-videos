# Copie ce fichier en .env et remplis les valeurs.
# Le .env est ignoré par git pour ne pas exposer tes clés.

# ─── LLM (scénario) — au moins UNE clé requise ──────────────────────────
# Mistral (recommandé, français) : https://console.mistral.ai
MISTRAL_API_KEY=
# Groq (gratuit, rapide) : https://console.groq.com/keys
GROQ_API_KEY=
# Gemini (gratuit avec quota) : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Banques d'images/vidéos stock ──────────────────────────────────────
# Pexels (gratuit) : https://www.pexels.com/api/
PEXELS_API_KEY=
# Pixabay (gratuit) : https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ─── Génération d'images IA — Cloudflare Workers AI ─────────────────────
# Free tier 10k neurons/jour (~130 images), sans carte bancaire.
# Setup : python scripts/setup_cloudflare.py
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# ─── Auto-publication TikTok (mode brouillon) ───────────────────────────
# Setup : python scripts/setup_tiktok.py
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_AUTO_PUBLISH=false

# ─── Notifications Telegram (brouillon prêt) ────────────────────────────
# Setup : python scripts/setup_telegram.py
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Voix ───────────────────────────────────────────────────────────────
# TTS_PROVIDER : "edge" (rapide, synthétique) ou "coqui" (humaine, lente CPU)
TTS_PROVIDER=coqui

# ─── Options avancées (valeurs par défaut OK) ───────────────────────────
# POLLINATIONS_ENABLED=true   # ancien provider IA, payant depuis mai 2026
# FFMPEG_PATH=C:\chemin\vers\ffmpeg.exe
